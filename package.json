{
  "name": "sobree-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Sobree — print-view-first WYSIWYG editor. Public monorepo (packages + docs).",
  "packageManager": "pnpm@10.34.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @sobree/playground dev",
    "dev:collab": "pnpm --filter @sobree/collab-server build && node scripts/dev-collab.mjs",
    "dev:docs": "pnpm --filter @sobree/docs dev",
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present test",
    "test:changed": "pnpm -F @sobree/core test -- --changed HEAD",
    "test:core": "pnpm -F @sobree/core test",
    "test:oracle": "pnpm -F @sobree/core test -- fixtures.oracle",
    "test:related": "node scripts/test-related.mjs",
    "typecheck": "pnpm -r --if-present typecheck",
    "preview": "pnpm --filter @sobree/docs preview",
    "check": "biome check .",
    "format": "biome format --write .",
    "fixtures:gen": "pnpm --filter @sobree/fixtures-gen gen",
    "fixtures:extract": "pnpm --filter @sobree/fixtures-gen extract",
    "corpus": "pnpm --filter @sobree/fixtures-gen corpus",
    "corpus:render": "pnpm --filter @sobree/fixtures-gen corpus:render",
    "corpus:diff": "pnpm --filter @sobree/fixtures-gen corpus:diff",
    "corpus:check": "pnpm --filter @sobree/fixtures-gen corpus:check",
    "corpus:baseline": "pnpm --filter @sobree/fixtures-gen corpus:baseline",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "build:packages": "pnpm --filter \"./packages/*\" build",
    "release": "pnpm build:packages && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.10",
    "@microsoft/api-extractor": "^7.58.7",
    "@sobree/collab-server": "workspace:*",
    "@types/node": "^22.10.2",
    "@vitest/ui": "^3.2.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^5.0.0",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vitest": "^3.2.4"
  }
}
