{
  "name": "@sobree/zoom-controls",
  "version": "0.1.50",
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./package.json": "./package.json"
    }
  },
  "description": "Floating zoom dock (zoom in/out, fit width, fit page) for @sobree/core viewports.",
  "keywords": [
    "sobree",
    "wysiwyg",
    "editor",
    "zoom",
    "viewport",
    "ui",
    "floating"
  ],
  "license": "MIT",
  "author": "sobree.dev",
  "homepage": "https://docs.sobree.dev/api/zoom-controls/",
  "bugs": {
    "url": "https://github.com/khayll/sobree/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khayll/sobree.git",
    "directory": "packages/zoom-controls"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
