{
  "name": "@sobree/core",
  "version": "0.1.48",
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./tokens.css": {
        "default": "./dist/tokens.css"
      },
      "./package.json": "./package.json"
    }
  },
  "description": "Embeddable, print-view-first WYSIWYG editor for .docx — framework-free core, plugin architecture, native OOXML round-trip.",
  "keywords": [
    "wysiwyg",
    "editor",
    "rich-text",
    "docx",
    "ooxml",
    "framework-free",
    "embeddable",
    "contenteditable",
    "pagination",
    "sobree"
  ],
  "license": "MIT",
  "author": "sobree.dev",
  "homepage": "https://docs.sobree.dev",
  "bugs": {
    "url": "https://github.com/khayll/sobree/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khayll/sobree.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": {
      "development": "./src/styles/tokens.css",
      "default": "./dist/tokens.css"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "vite build && cp src/styles/tokens.css dist/tokens.css",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "yjs": "^13.6.30"
  }
}
